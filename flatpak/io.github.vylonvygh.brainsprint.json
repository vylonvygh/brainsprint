{
    "app-id": "io.github.vylonvygh.brainsprint",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "23.08",
    "sdk": "org.freedesktop.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "command": "brainsprint",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--filesystem=xdg-data/brainsprint:create"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin",
        "env": {
            "CARGO_HOME": "/run/build/brainsprint/cargo"
        }
    },
    "modules": [
        {
            "name": "brainsprint",
            "buildsystem": "simple",
            "build-commands": [
                "cargo --offline build --release",
                "install -Dm755 target/release/brainsprint /app/bin/brainsprint",
                "install -Dm644 flatpak/io.github.vylonvygh.brainsprint.desktop /app/share/applications/io.github.vylonvygh.brainsprint.desktop",
                "install -Dm644 flatpak/io.github.vylonvygh.brainsprint.metainfo.xml /app/share/metainfo/io.github.vylonvygh.brainsprint.metainfo.xml",
                "install -Dm644 flatpak/icons/64x64.png /app/share/icons/hicolor/64x64/apps/io.github.vylonvygh.brainsprint.png",
                "install -Dm644 flatpak/icons/128x128.png /app/share/icons/hicolor/128x128/apps/io.github.vylonvygh.brainsprint.png",
                "install -Dm644 flatpak/icons/256x256.png /app/share/icons/hicolor/256x256/apps/io.github.vylonvygh.brainsprint.png",
                "install -Dm644 flatpak/icons/512x512.png /app/share/icons/hicolor/512x512/apps/io.github.vylonvygh.brainsprint.png"
            ],
            "sources": [
    {
        "type": "dir",
        "path": "../"
    },
    "cargo-sources.json"
]
        }
    ]
}
