{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "BrainSprint",
  "version": "1.0.0",
  "identifier": "com.brainsprint.app",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "windows": [
      {
        "title": "BrainSprint",
        "width": 1100,
        "height": 750,
        "resizable": true,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "assets/logo.svg",
      "assets/app-logo.png"
    ]
  }
}
